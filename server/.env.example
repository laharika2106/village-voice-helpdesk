PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/village_voice_helpdesk
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads

# Google Translate. Keep this server-side only.
# Option 1: API key
GOOGLE_TRANSLATE_API_KEY=
# Option 2: Application credentials file path
GOOGLE_APPLICATION_CREDENTIALS=

# Used only by npm run create-admin
ADMIN_NAME=
ADMIN_PHONE=
ADMIN_PASSWORD=
ADMIN_VILLAGE=

# Used only by npm run create-staff
STAFF_NAME=
STAFF_PHONE=
STAFF_PASSWORD=
STAFF_VILLAGE=
STAFF_ROLE=panchayat_member
